# ─────────────────────────────────────────────────────────
#  Mortgage Broker Agent — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# REQUIRED: Your Anthropic API key
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Flask secret key (generate a strong random string for production)
SECRET_KEY=change-me-to-a-long-random-string-in-production

# Server settings
PORT=5000
FLASK_ENV=development
DEBUG=false

# Document output path (host path for volume mount)
DOCS_OUTPUT_PATH=./generated_documents
